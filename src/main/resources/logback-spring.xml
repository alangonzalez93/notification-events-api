<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
      Plain-text format for local development — readable in the terminal.
      Activated by the "local" Spring profile.
    -->
    <springProfile name="local">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %-40logger{40} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.cobre.notifications" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
    </springProfile>

    <!--
      JSON format for all other profiles (dev, staging, prod).
      LogstashEncoder includes MDC fields (notificationId, clientId, eventType)
      automatically in every log line — no extra configuration needed.
    -->
    <springProfile name="!local">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeCallerData>false</includeCallerData>
                <fieldNames>
                    <timestamp>timestamp</timestamp>
                    <message>message</message>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <level>level</level>
                </fieldNames>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
        <logger name="com.cobre.notifications" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
        <logger name="org.flywaydb" level="INFO"/>
    </springProfile>

</configuration>
